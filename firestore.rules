rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return request.auth != null && userData().role == 'admin';
    }
    function isLoggedIn() {
      return request.auth != null;
    }

    // Users — admin can read all, users can read own doc
    // Note: create allowed for any authenticated user (setup + admin creating users)
    match /users/{userId} {
      allow read: if isLoggedIn();
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Routes — users can CRUD their own, admin can read all
    match /routes/{routeId} {
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isLoggedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isLoggedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update: if isLoggedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
